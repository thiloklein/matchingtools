{
  "name": "MatchingMarkets-openapi-spec",
  "version": "0.0.1",
  "dependencies": {
    "bower": "^1.7.7",
    "connect": "^3.4.1",
    "cors": "^2.7.1",
    "deploy-to-gh-pages": "^1.1.0",
    "gulp": "^5.0.1",
    "gulp-connect": "^5.7.0",
    "gulp-util": "^1.0.0",
    "portfinder": "^1.0.3",
    "shelljs": "^0.10.0",
    "swagger-ui-dist": "^5.0.0"
  },
  "private": true,
  "scripts": {
    "deploy": "npm run build && deploy-to-gh-pages --update web_deploy",
    "build": "node ./scripts/build.js",
    "swagger": "redocly bundle spec/swagger.yaml -o web_deploy/swagger.yaml && redocly bundle spec/swagger.yaml -o web_deploy/swagger.json --ext json",
    "test": "redocly lint spec/swagger.yaml",
    "start": "gulp serve",
    "deploy-branch": "node ./scripts/deploy-branch.js"
  },
  "devDependencies": {
    "@redocly/cli": "^2.20.3",
    "minimatch": "^3.0.4"
  }
}
